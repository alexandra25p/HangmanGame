<Window x:Class="HangmanGame.View.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Hangman" Height="350" Width="450" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F0FA">

    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Hangman Game" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#4A306D" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,10"/>

    
            <Border BorderBrush="#D4C4F0" BorderThickness="0,1,0,1" Padding="0,20">
                <StackPanel>
                    <TextBlock Text="Paraschiv Alexandra Andreea" 
                               FontSize="18" 
                               Foreground="#4A306D" 
                               HorizontalAlignment="Center" 
                               Margin="0,5"/>
                    <TextBlock Text="Grupa 10LF342" 
                               FontSize="14" 
                               Foreground="#4A306D" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Informatica Aplicata" 
                               FontSize="14" 
                               Foreground="#4A306D" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Button Content="Close" 
                    Width="100" 
                    Height="35" 
                    Margin="0,30,0,0"
                    Background="#EADDF8" 
                    Foreground="#4A306D" 
                    FontWeight="Bold" 
                    Click="BtnClose_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>