<Window x:Class="HangmanGame.View.NewUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New User" Height="560" Width="420" WindowStartupLocation="CenterScreen"
        Background="#F4F0FA">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A306D"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#4A306D"/>
            <Setter Property="BorderBrush" Value="#D4C4F0"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#D4C4F0"/>
            <Setter Property="Foreground" Value="#4A306D"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BFA8E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Username (un singur cuvant):" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="TxtName" Grid.Row="1" Margin="0,0,0,15" Padding="5" Height="30" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="2" Text="1. Alege un avatar predefinit:" FontWeight="Bold" Margin="0,0,0,5"/>

        <ListBox x:Name="LstPredefined" Grid.Row="3" SelectionChanged="LstPredefined_SelectionChanged" 
                 Margin="0,0,0,15" Background="Transparent" BorderThickness="0" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#D4C4F0" BorderThickness="2" CornerRadius="10" Margin="5" Background="White">
                        <Image Source="{Binding}" Width="75" Height="75" Stretch="UniformToFill" Margin="3"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="4" Text="2. Sau alege o imagine de pe PC:" FontWeight="Bold" Margin="0,0,0,5"/>
        <Button x:Name="BtnBrowse" Grid.Row="5" Content="Răsfoiește (Browse...)" Click="BtnBrowse_Click" Margin="0,0,0,10"/>

        <Grid Grid.Row="6" Margin="0,5,0,0">
            <TextBlock x:Name="TxtPath" Text="Nicio imagine selectată" FontStyle="Italic" Foreground="#85739C" TextWrapping="Wrap" Margin="0,0,175,0" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="Salvează" Click="BtnSave_Click" Width="80" Margin="0,0,10,0"/>
                <Button Content="Anulează" Click="BtnCancel_Click" Width="80" Background="#EADDF8" Foreground="#4A306D"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>