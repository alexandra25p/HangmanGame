<Window x:Class="HangmanGame.View.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Statistici Detaliate" Height="520" Width="680"
        WindowStartupLocation="CenterScreen" Background="#F4F4F9">

    <Window.Resources>
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4B2C5E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="STATISTICI JUCĂTORI" FontSize="24" FontWeight="Bold" 
                   Foreground="#4B2C5E" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="#E9E9F0" CornerRadius="5" Padding="10" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Categorie:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="CategoryFilterCombo" Width="140" Height="28" Margin="0,0,15,0"
                          SelectionChanged="CategoryFilter_Changed" VerticalContentAlignment="Center"/>

                <Button Content="Profilul Meu" Style="{StaticResource FlatButtonStyle}" 
                        Click="MyStats_Click" Background="#2196F3" Width="110" Margin="0,0,10,0"/>

                <Button Content="Reset" Style="{StaticResource FlatButtonStyle}" 
                        Click="ShowAll_Click" Background="#757575" Width="70"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="StatsDataGrid" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" CanUserAddRows="False" 
                  Background="White" BorderBrush="#DDD" RowHeight="32"
                  AlternatingRowBackground="#FDFDFD" GridLinesVisibility="Horizontal" 
                  HorizontalGridLinesBrush="#EEE">

            <DataGrid.Columns>
                <DataGridTextColumn Header="UTILIZATOR" Binding="{Binding User}" Width="*"/>
                <DataGridTextColumn Header="CATEGORIE" Binding="{Binding Category}" Width="1.3*"/>
                <DataGridTextColumn Header="JUCATE" Binding="{Binding Played}" Width="80"/>
                <DataGridTextColumn Header="CÂȘTIGATE" Binding="{Binding Won}" Width="80"/>
                <DataGridTextColumn Header="SUCCES (%)" Binding="{Binding WinPercent, StringFormat={}{0:F1}%}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#2E7D32"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3" Content="Înapoi la Joc" Style="{StaticResource FlatButtonStyle}"
                Click="Close_Click" Width="120" Height="30" Margin="0,15,0,0" HorizontalAlignment="Center"/>
    </Grid>
</Window>